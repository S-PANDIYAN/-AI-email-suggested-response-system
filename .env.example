# Copy this file to ".env" and fill in ONE provider key to enable real LLM
# generation + LLM-as-judge. With no key present, the system automatically
# uses the deterministic Mock provider so it still runs end-to-end.

# Groq (recommended for assessments: fast, free tier, OpenAI-compatible)
GROQ_API_KEY=
# OpenAI
OPENAI_API_KEY=

# Google Gemini
GEMINI_API_KEY=
